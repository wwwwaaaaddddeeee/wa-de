---
import Layout from "../layouts/Layout.astro";
import DitheredLogoDemo from "../components/DitheredLogoDemo";
import Earworm from "../components/Earworm";
import {
  LinkedInIcon,
  XIcon,
  InstagramIcon,
  GitHubIcon,
} from "../components/SocialIcons";
---

<Layout>
  <main class="min-h-screen overflow-hidden relative" style="background: var(--background);">
    <div class="absolute top-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-6">
      <p class="font-normal text-center inline-flex items-center gap-1" style="color: var(--foreground); font-size: 13px;">
        Designer, Memphis, TN,&nbsp;<span class="wade-tip underline underline-offset-2">wade<span class="wade-tip-label" role="tooltip">wade@hellowade.dev</span></span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          style="flex-shrink: 0;"
        >
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
          <path
            d="M15 9L9 15M15 13V9H11"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </p>
      <div class="social-row flex flex-wrap items-center justify-center gap-3">
        <LinkedInIcon client:load />
        <XIcon client:load />
        <InstagramIcon client:load />
        <GitHubIcon client:load />
      </div>
      <Earworm client:load />
    </div>

    <div class="wade-sheet" aria-hidden="true">
      <button class="wade-sheet-backdrop" type="button" aria-label="Close"></button>
      <div class="wade-sheet-card" role="dialog" aria-modal="true" aria-labelledby="wade-sheet-title">
        <div class="wade-sheet-handle" aria-hidden="true"></div>
        <p id="wade-sheet-title" class="wade-sheet-title">Let's connect</p>
        <a class="wade-sheet-email" href="mailto:wade@hellowade.dev">wade@hellowade.dev</a>
        <button class="wade-sheet-copy" type="button">Copy email</button>
      </div>
    </div>

    <style is:global>
      .social-row svg {
        width: 21.675px;
        height: 21.675px;
      }
      .wade-tip {
        position: relative;
      }
      .wade-tip-label {
        position: absolute;
        top: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%) translateY(-4px);
        background: var(--foreground);
        color: var(--background);
        font-size: 11px;
        line-height: 1;
        padding: 6px 9px;
        border-radius: 6px;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 150ms ease, transform 150ms ease;
        text-decoration: none;
      }
      .wade-tip-label::before {
        content: "";
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 4px solid transparent;
        border-bottom-color: var(--foreground);
      }
      @media (hover: hover) {
        .wade-tip:hover .wade-tip-label {
          opacity: 1;
          transform: translateX(-50%) translateY(0);
        }
      }

      /* Bottom sheet (mobile only; desktop keeps the tooltip) */
      .wade-sheet {
        position: fixed;
        inset: 0;
        z-index: 50;
        pointer-events: none;
      }
      .wade-sheet[aria-hidden="false"] {
        pointer-events: auto;
      }
      .wade-sheet-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        border: 0;
        padding: 0;
        cursor: pointer;
        opacity: 0;
        transition: opacity 200ms ease;
      }
      .wade-sheet[aria-hidden="false"] .wade-sheet-backdrop {
        opacity: 1;
      }
      .wade-sheet-card {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        background: var(--background);
        color: var(--foreground);
        border-radius: 18px 18px 0 0;
        padding: 14px 20px calc(24px + env(safe-area-inset-bottom, 0));
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 12px;
        transform: translateY(100%);
        transition: transform 260ms cubic-bezier(0.22, 0.61, 0.36, 1);
        box-shadow: 0 -8px 30px rgba(0, 0, 0, 0.18);
      }
      .wade-sheet[aria-hidden="false"] .wade-sheet-card {
        transform: translateY(0);
      }
      .wade-sheet-handle {
        width: 36px;
        height: 4px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.2);
        margin: 0 auto 6px;
      }
      .wade-sheet-title {
        font-size: 13px;
        font-weight: 500;
        margin: 0;
        color: var(--muted);
        text-align: center;
      }
      .wade-sheet-email {
        font-size: 20px;
        font-weight: 500;
        text-align: center;
        color: var(--foreground);
        text-decoration: none;
        padding: 4px 0;
      }
      .wade-sheet-copy {
        font: inherit;
        font-size: 14px;
        font-weight: 500;
        background: var(--foreground);
        color: var(--background);
        border: 0;
        border-radius: 999px;
        padding: 12px 18px;
        cursor: pointer;
        transition: opacity 150ms ease;
      }
      .wade-sheet-copy:active {
        opacity: 0.8;
      }
      @media (hover: hover) {
        .wade-sheet {
          display: none;
        }
      }
    </style>
    <DitheredLogoDemo client:only="react" />
  </main>
</Layout>

<script>
  const EMAIL = "wade@hellowade.dev";
  const isTouch = window.matchMedia("(hover: none)").matches;

  const tip = document.querySelector<HTMLElement>(".wade-tip");
  const sheet = document.querySelector<HTMLElement>(".wade-sheet");
  const backdrop = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-backdrop");
  const copyBtn = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-copy");
  const emailLink = sheet?.querySelector<HTMLAnchorElement>(".wade-sheet-email");

  const open = () => {
    sheet?.setAttribute("aria-hidden", "false");
    document.documentElement.style.overflow = "hidden";
  };
  const close = () => {
    sheet?.setAttribute("aria-hidden", "true");
    document.documentElement.style.overflow = "";
  };

  tip?.addEventListener("click", (e) => {
    if (!isTouch) return;
    e.preventDefault();
    open();
  });

  backdrop?.addEventListener("click", close);
  emailLink?.addEventListener("click", () => setTimeout(close, 200));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && sheet?.getAttribute("aria-hidden") === "false") close();
  });

  copyBtn?.addEventListener("click", async () => {
    if (!copyBtn) return;
    try {
      await navigator.clipboard.writeText(EMAIL);
      const original = copyBtn.textContent;
      copyBtn.textContent = "Copied!";
      setTimeout(() => { copyBtn.textContent = original; }, 1400);
    } catch {
      // clipboard denied — fallback: select email text
      const range = document.createRange();
      if (emailLink) {
        range.selectNodeContents(emailLink);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
    }
  });
</script>
