---
import Layout from '@/layouts/Layout.astro'
import { EmailPill } from '@/components/EmailPill'
import Earworm from '@/components/Earworm'
import { RabitHoleCard } from '@/components/RabitHoleCard'
import SocialIcon from '@/components/SocialIcon.astro'

const socials = [
  { label: 'GitHub', href: 'https://github.com/', icon: 'github' as const },
  { label: 'LinkedIn', href: 'https://linkedin.com/', icon: 'linkedin' as const },
  { label: 'Bird', href: 'https://x.com/', icon: 'x' as const },
  { label: 'Instagram', href: 'https://instagram.com/', icon: 'instagram' as const },
]
---

<Layout title="Wade — Designer in Memphis">
  <main class="min-h-screen w-full bg-white text-[#1a1a1a] dark:bg-[#171717] dark:text-[#ededed]">
    <div class="mx-auto w-full max-w-2xl px-[35px] sm:px-12 pt-16 sm:pt-20 pb-16 flex flex-col items-start gap-4">
      <img src="/avatar.png" alt="Wade" width="40" height="40" class="rounded-full" />

      <p class="text-[14px] leading-[21px] sm:text-[15px] sm:leading-[22px] text-[#2e2e2e] dark:text-[#cfcfcf]">
        <span class="font-semibold text-[#1a1a1a] dark:text-[#ededed]">Wade</span>
        <span class="ml-1.5 italic text-[#8c8c8c] dark:text-[#8b8b8b]">@brianawade</span>
        <span class="mx-2 text-[#9a9a9a] dark:text-[#777]" aria-hidden="true">—</span>
        Designing, learning and building in Memphis, TN with big Human Interface dreams.
      </p>

      <h2 class="text-[11px] tracking-tight text-[#e0e0e0] pt-10 pb-2 dark:text-[#2a2a2a]">
        Online
      </h2>

      <div class="flex flex-wrap items-center gap-1.5">
        <EmailPill client:load email="wade@hellowade.dev" />
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 rounded-[5px] bg-[#f6f6f6] px-2.5 py-1.5 text-[12px] transition-colors hover:bg-[#efefef] sm:gap-1 sm:px-2 sm:py-1 sm:text-[11px] dark:bg-[#222] dark:hover:bg-[#2e2e2e]"
          >
            <span class="text-[#0A0A0D] dark:text-[#ededed]">
              <SocialIcon name={s.icon} size={12} />
            </span>
            <span class="text-[#1F1F1F] dark:text-[#777]">{s.label}</span>
          </a>
        ))}
        <Earworm client:load />
      </div>

      <div class="h-6"></div>

      <h2 class="text-[11px] tracking-tight text-[#e0e0e0] pb-2 dark:text-[#2a2a2a]">
        Work
      </h2>

      <div class="flex w-full items-start gap-3">
        <div class="w-1/4">
          <RabitHoleCard client:load />
        </div>
        <a
          href="https://rabit.wtf"
          target="_blank"
          rel="noreferrer"
          class="mt-3.5 inline-flex items-center gap-0.5 rounded-full border border-[#FF5C00] px-2.5 py-0.5 text-[12px] text-[#FF5C00] hover:text-[#FF0000] hover:border-[#FF0000]"
        >
          rabit.wtf
          <svg
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 7L7 3" />
            <path d="M3.5 3H7v3.5" />
          </svg>
        </a>
        <div class="w-1/4 aspect-square rounded-xl bg-[#EEF5EC] dark:bg-[#1f2a1d]"></div>
        <a
          href="https://ref.garden"
          target="_blank"
          rel="noreferrer"
          class="mt-3.5 inline-flex items-center gap-0.5 rounded-full border border-[#3F7D3A] px-2.5 py-0.5 text-[12px] text-[#3F7D3A] hover:text-[#2A5C26] hover:border-[#2A5C26]"
        >
          ref.garden
          <svg
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 7L7 3" />
            <path d="M3.5 3H7v3.5" />
          </svg>
        </a>
      </div>
    </div>
  </main>
</Layout>
