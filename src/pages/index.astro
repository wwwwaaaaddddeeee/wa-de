---
import Layout from "../layouts/Layout.astro";
import DitheredLogoDemo from "../components/DitheredLogoDemo";
import Earworm from "../components/Earworm";
import {
  LinkedInIcon,
  XIcon,
  InstagramIcon,
  GitHubIcon,
} from "../components/SocialIcons";
---

<Layout>
  <main class="min-h-screen overflow-hidden relative" style="background: var(--background);">
    <div class="absolute inset-x-0 top-0 bottom-[calc(50%+100px)] sm:bottom-[calc(50%+163px)] z-10 flex flex-col items-center pt-6 pointer-events-none">
      <p class="font-normal text-center inline-flex items-center gap-1 pointer-events-auto" style="color: var(--foreground); font-size: 13px;">
        <span class="wade-tip underline underline-offset-2">wade<span class="wade-tip-label" role="tooltip">wade@hellowade.dev</span></span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          style="flex-shrink: 0;"
        >
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
          <path
            d="M15 9L9 15M15 13V9H11"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </p>
      <div class="flex-1 flex items-center justify-center pointer-events-auto">
        <Earworm client:load />
      </div>
    </div>

    <div class="wade-sheet" aria-hidden="true">
      <button class="wade-sheet-backdrop" type="button" aria-label="Close"></button>
      <div class="wade-sheet-card" role="dialog" aria-modal="true" aria-labelledby="wade-sheet-title">
        <button class="wade-sheet-close" type="button" aria-label="Close">
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M3 3L9 9M9 3L3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>
        <p id="wade-sheet-title" class="wade-sheet-bio">
          Hello — a designer living, learning and working in Memphis, TN. Currently building rabit.wtf and other projects.
        </p>
        <div class="wade-sheet-socials">
          <LinkedInIcon client:load />
          <XIcon client:load />
          <InstagramIcon client:load />
          <GitHubIcon client:load />
        </div>
        <div class="wade-sheet-email-row">
          <span class="wade-sheet-email">wade@hellowade.dev</span>
          <button class="wade-sheet-copy" type="button">Copy</button>
        </div>
      </div>
    </div>

    <style is:global>
      .social-row svg {
        width: 21.675px;
        height: 21.675px;
      }
      .wade-tip {
        position: relative;
      }
      .wade-tip-label {
        position: absolute;
        top: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%) translateY(-4px);
        background: var(--foreground);
        color: var(--background);
        font-size: 11px;
        line-height: 1;
        padding: 6px 9px;
        border-radius: 6px;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 150ms ease, transform 150ms ease;
        text-decoration: none;
      }
      .wade-tip-label::before {
        content: "";
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 4px solid transparent;
        border-bottom-color: var(--foreground);
      }
      @media (hover: hover) {
        .wade-tip:hover .wade-tip-label {
          opacity: 1;
          transform: translateX(-50%) translateY(0);
        }
      }

      /* Bottom sheet (mobile only; desktop keeps the tooltip) */
      .wade-sheet {
        position: fixed;
        inset: 0;
        z-index: 50;
        pointer-events: none;
      }
      .wade-sheet[aria-hidden="false"] {
        pointer-events: auto;
      }
      .wade-sheet-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.18);
        border: 0;
        padding: 0;
        cursor: pointer;
        opacity: 0;
        transition: opacity 200ms ease;
      }
      .wade-sheet[aria-hidden="false"] .wade-sheet-backdrop {
        opacity: 1;
      }
      .wade-sheet-card {
        position: absolute;
        top: 50%;
        left: 50%;
        width: calc(100% - 32px);
        max-width: 360px;
        /* Frosted liquid-glass: translucent base tinted to page bg, blur +
           saturate to lift color through, soft highlight gradient on top for
           a specular feel, and inset highlights for the glass edge. */
        background:
          linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.38),
            rgba(255, 255, 255, 0) 55%,
            rgba(255, 255, 255, 0.08)
          ),
          color-mix(in srgb, var(--background) 52%, transparent);
        backdrop-filter: blur(34px) saturate(180%);
        -webkit-backdrop-filter: blur(34px) saturate(180%);
        color: var(--foreground);
        border-radius: 24px;
        padding: 16px 18px 20px;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 14px;
        transform: translate(-50%, -50%) scale(0.94);
        opacity: 0;
        transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
                    opacity 200ms ease;
        box-shadow:
          0 14px 40px rgba(0, 0, 0, 0.14),
          0 2px 6px rgba(0, 0, 0, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.75),
          inset 0 -1px 0 rgba(0, 0, 0, 0.04),
          inset 0 0 0 0.5px rgba(255, 255, 255, 0.18);
      }
      @media (prefers-color-scheme: dark) {
        .wade-sheet-card {
          background:
            linear-gradient(
              180deg,
              rgba(255, 255, 255, 0.1),
              rgba(255, 255, 255, 0) 55%,
              rgba(255, 255, 255, 0.02)
            ),
            color-mix(in srgb, var(--background) 55%, transparent);
          box-shadow:
            0 30px 80px rgba(0, 0, 0, 0.55),
            0 4px 14px rgba(0, 0, 0, 0.35),
            inset 0 1px 0 rgba(255, 255, 255, 0.14),
            inset 0 -1px 0 rgba(0, 0, 0, 0.3),
            inset 0 0 0 0.5px rgba(255, 255, 255, 0.06);
        }
      }
      .wade-sheet[aria-hidden="false"] .wade-sheet-card {
        transform: translate(-50%, -50%) scale(1);
        opacity: 1;
      }
      .wade-sheet-close {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 28px;
        height: 28px;
        padding: 0;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.06);
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 150ms ease, color 150ms ease;
      }
      .wade-sheet-close:hover {
        background: rgba(0, 0, 0, 0.1);
      }
      .wade-sheet-close:active {
        opacity: 0.8;
      }
      .wade-sheet-bio {
        margin: 4px 36px 0 4px; /* reserve right space for the close button */
        font-size: 14px;
        line-height: 1.5;
        color: var(--foreground);
      }
      .wade-sheet-socials {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 2px 0 4px;
      }
      .wade-sheet-socials svg {
        width: 22px;
        height: 22px;
      }
      .wade-sheet-email-row {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 0, 0, 0.05);
        border-radius: 999px;
        padding: 5px 5px 5px 14px;
        height: 40px;
      }
      .wade-sheet-email {
        flex: 1;
        font-size: 13px;
        color: var(--foreground);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .wade-sheet-copy {
        font: inherit;
        font-size: 12px;
        font-weight: 500;
        background: #000;
        color: #fff;
        border: 0;
        border-radius: 999px;
        height: 30px;
        padding: 0 14px;
        cursor: pointer;
        transition: opacity 150ms ease, transform 150ms ease;
      }
      .wade-sheet-copy:active {
        transform: scale(0.96);
        opacity: 0.92;
      }
      @media (hover: hover) {
        .wade-sheet {
          display: none;
        }
      }
    </style>
    <DitheredLogoDemo client:only="react" />
  </main>
</Layout>

<script>
  const EMAIL = "wade@hellowade.dev";
  const isTouch = window.matchMedia("(hover: none)").matches;

  const tip = document.querySelector<HTMLElement>(".wade-tip");
  const sheet = document.querySelector<HTMLElement>(".wade-sheet");
  const backdrop = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-backdrop");
  const closeBtn = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-close");
  const copyBtn = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-copy");
  const emailEl = sheet?.querySelector<HTMLElement>(".wade-sheet-email");

  const open = () => {
    sheet?.setAttribute("aria-hidden", "false");
    document.documentElement.style.overflow = "hidden";
  };
  const close = () => {
    sheet?.setAttribute("aria-hidden", "true");
    document.documentElement.style.overflow = "";
  };

  tip?.addEventListener("click", (e) => {
    if (!isTouch) return;
    e.preventDefault();
    open();
  });

  backdrop?.addEventListener("click", close);
  closeBtn?.addEventListener("click", close);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && sheet?.getAttribute("aria-hidden") === "false") close();
  });

  copyBtn?.addEventListener("click", async () => {
    if (!copyBtn) return;
    try {
      await navigator.clipboard.writeText(EMAIL);
      const original = copyBtn.textContent;
      copyBtn.textContent = "Copied!";
      setTimeout(() => { copyBtn.textContent = original; }, 1400);
    } catch {
      // clipboard denied — fallback: select the email text so the user can
      // long-press → copy manually
      if (emailEl) {
        const range = document.createRange();
        range.selectNodeContents(emailEl);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
    }
  });
</script>
