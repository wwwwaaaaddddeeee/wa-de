---
import Layout from "../layouts/Layout.astro";
import DitheredLogoDemo from "../components/DitheredLogoDemo";
import Earworm from "../components/Earworm";
import {
  LinkedInIcon,
  XIcon,
  InstagramIcon,
  GitHubIcon,
} from "../components/SocialIcons";
---

<Layout>
  <main class="min-h-screen overflow-hidden relative" style="background: var(--background);">
    <div class="absolute inset-x-0 top-0 bottom-[calc(50%+100px)] sm:bottom-[calc(50%+163px)] z-10 flex flex-col items-center pt-6 pointer-events-none">
      <p class="font-normal text-center inline-flex items-center gap-1 pointer-events-auto" style="color: var(--foreground); font-size: 15px;">
        <span class="wade-tip underline underline-offset-2">wade</span>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          style="flex-shrink: 0;"
        >
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
          <path
            d="M15 9L9 15M15 13V9H11"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </p>
      <div class="flex-1 flex items-center justify-center pointer-events-auto">
        <Earworm client:load />
      </div>
    </div>

    <div class="wade-sheet" aria-hidden="true">
      <button class="wade-sheet-backdrop" type="button" aria-label="Close"></button>
      <div class="wade-sheet-card" role="dialog" aria-modal="true" aria-labelledby="wade-sheet-title">
        <div class="wade-sheet-handle" aria-hidden="true"></div>
        <button class="wade-sheet-close" type="button" aria-label="Close">
          <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M3 3L9 9M9 3L3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </button>
        <div class="wade-sheet-intro">
          <h3 id="wade-sheet-title" class="wade-sheet-greeting" aria-label="hello">
            <span class="wade-letter">h</span><span class="wade-letter">e</span><span class="wade-letter">l</span><span class="wade-letter">l</span><span class="wade-letter">o</span>
          </h3>
          <p class="wade-sheet-bio">
            Call me Wade — Designing, learning, and building in Memphis, TN.
          </p>
          <p class="wade-sheet-section-heading">Currently working on:</p>
          <a class="wade-sheet-logo-link" href="http://rabit.wtf" target="_blank" rel="noopener noreferrer" aria-label="rabit.wtf">
            <img class="wade-sheet-logo" src="/logos/rabit.svg" alt="rabit.wtf" width="40" height="40" />
          </a>
        </div>
        <div class="wade-sheet-bottom">
          <span class="wade-sheet-email">wade@hellowade.dev</span>
          <button class="wade-sheet-copy" type="button" aria-label="Copy email">
            <svg class="wade-copy-icon" width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="7" y="7" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.5" />
              <path d="M13 7V5a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <svg class="wade-check-icon" width="15" height="15" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="18" height="18" rx="5" fill="#22c55e" />
              <path d="M6 10.5L9 13.5L14.5 7.5" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <div class="wade-sheet-socials">
            <LinkedInIcon client:load />
            <XIcon client:load />
            <InstagramIcon client:load />
            <GitHubIcon client:load />
          </div>
        </div>
      </div>
    </div>

    <style is:global>
      .social-row svg {
        width: 21.675px;
        height: 21.675px;
      }
      .wade-tip {
        cursor: pointer;
        display: inline-block;
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), opacity 180ms ease;
        transform-origin: center;
      }
      @media (hover: hover) {
        .wade-tip:hover {
          transform: translateY(-1px);
          opacity: 0.78;
        }
      }
      .wade-tip:active {
        transform: scale(0.96);
        opacity: 0.7;
      }

      /* Bottom sheet (mobile only; desktop keeps the tooltip) */
      .wade-sheet {
        position: fixed;
        inset: 0;
        z-index: 50;
        pointer-events: none;
      }
      .wade-sheet[aria-hidden="false"] {
        pointer-events: auto;
      }
      .wade-sheet-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.18);
        border: 0;
        padding: 0;
        cursor: pointer;
        opacity: 0;
        transition: opacity 200ms ease;
      }
      .wade-sheet[aria-hidden="false"] .wade-sheet-backdrop {
        opacity: 1;
      }
      .wade-sheet-card {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        margin: 0 auto;
        width: 100%;
        max-width: 520px;
        /* Frosted liquid-glass: translucent base tinted to page bg, blur +
           saturate to lift color through, soft highlight gradient on top for
           a specular feel, and inset highlights for the glass edge. */
        background:
          linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.38),
            rgba(255, 255, 255, 0) 55%,
            rgba(255, 255, 255, 0.08)
          ),
          color-mix(in srgb, var(--background) 52%, transparent);
        backdrop-filter: blur(34px) saturate(180%);
        -webkit-backdrop-filter: blur(34px) saturate(180%);
        color: var(--foreground);
        border-radius: 20px 20px 0 0;
        padding: 8px 22px calc(28px + env(safe-area-inset-bottom, 0));
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 16px;
        transform: translateY(100%);
        transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
        touch-action: none; /* pointer events drive the drag, not native scroll */
        box-shadow:
          0 -14px 40px rgba(0, 0, 0, 0.14),
          0 -2px 6px rgba(0, 0, 0, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.75),
          inset 0 0 0 0.5px rgba(255, 255, 255, 0.18);
      }
      .wade-sheet-card.dragging {
        transition: none;
      }
      .wade-sheet-handle {
        width: 36px;
        height: 4px;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.18);
        margin: 0 auto 4px;
        flex-shrink: 0;
      }
      @media (prefers-color-scheme: dark) {
        .wade-sheet-card {
          background:
            linear-gradient(
              180deg,
              rgba(255, 255, 255, 0.1),
              rgba(255, 255, 255, 0) 55%,
              rgba(255, 255, 255, 0.02)
            ),
            color-mix(in srgb, var(--background) 55%, transparent);
          box-shadow:
            0 -20px 60px rgba(0, 0, 0, 0.45),
            0 -2px 10px rgba(0, 0, 0, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.14),
            inset 0 0 0 0.5px rgba(255, 255, 255, 0.06);
        }
      }
      .wade-sheet[aria-hidden="false"] .wade-sheet-card {
        transform: translateY(0);
      }
      .wade-sheet-close {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 28px;
        height: 28px;
        padding: 0;
        border: 0;
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.06);
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 150ms ease, color 150ms ease;
      }
      .wade-sheet-close:hover {
        background: rgba(0, 0, 0, 0.1);
      }
      .wade-sheet-close:active {
        opacity: 0.8;
      }
      .wade-sheet-intro {
        margin: 0 36px 0 4px; /* reserve right space for the close button */
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .wade-sheet-greeting {
        margin: 0;
        font-family: "Geist Pixel", monospace;
        font-size: 44px;
        font-weight: 400;
        line-height: 1;
        color: var(--foreground);
        display: inline-flex;
        overflow: hidden; /* clip letters while they slide up */
      }
      .wade-letter {
        display: inline-block;
        transform: translateY(110%);
        opacity: 0;
        transition:
          transform 650ms cubic-bezier(0.22, 1, 0.36, 1),
          opacity 420ms ease;
      }
      .wade-sheet[aria-hidden="false"] .wade-letter {
        transform: translateY(0);
        opacity: 1;
      }
      /* Staggered per-letter entrance — each one delayed a little more than
         the previous so the word rolls in character by character. */
      .wade-sheet[aria-hidden="false"] .wade-letter:nth-child(1) { transition-delay: 120ms; }
      .wade-sheet[aria-hidden="false"] .wade-letter:nth-child(2) { transition-delay: 180ms; }
      .wade-sheet[aria-hidden="false"] .wade-letter:nth-child(3) { transition-delay: 240ms; }
      .wade-sheet[aria-hidden="false"] .wade-letter:nth-child(4) { transition-delay: 300ms; }
      .wade-sheet[aria-hidden="false"] .wade-letter:nth-child(5) { transition-delay: 360ms; }
      .wade-sheet-bio {
        margin: 0;
        font-size: 14px;
        line-height: 1.5;
        color: var(--foreground);
      }
      .wade-sheet-section-heading {
        margin: 28px 0 0 0; /* two-line break above — bigger than the default intro gap */
        font-size: 14px;
        line-height: 1.5;
        color: var(--foreground);
      }
      .wade-sheet-logo-link {
        display: inline-block;
        align-self: flex-start;
        transition: transform 150ms ease, opacity 150ms ease;
      }
      .wade-sheet-logo-link:hover {
        transform: scale(1.05);
      }
      .wade-sheet-logo-link:active {
        opacity: 0.85;
      }
      .wade-sheet-logo {
        display: block;
        width: 40px;
        height: 40px;
        /* Source SVG is painted in light gray for dark bg — invert in light
           mode so the shape reads on the pale card background. */
        filter: invert(1);
      }
      @media (prefers-color-scheme: dark) {
        .wade-sheet-logo {
          filter: none;
        }
      }
      .wade-sheet-bottom {
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .wade-sheet-email {
        font-size: 13px;
        color: var(--foreground);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .wade-sheet-socials {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .wade-sheet-socials svg {
        width: 18px;
        height: 18px;
      }
      .wade-sheet-copy {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: color 150ms ease, transform 150ms ease;
      }
      .wade-sheet-copy:hover {
        color: var(--foreground);
      }
      .wade-sheet-copy:active {
        transform: scale(0.92);
      }
      .wade-check-icon {
        display: none;
      }
      .wade-sheet-copy[data-copied="true"] .wade-copy-icon {
        display: none;
      }
      .wade-sheet-copy[data-copied="true"] .wade-check-icon {
        display: inline;
      }
    </style>
    <DitheredLogoDemo client:only="react" />
  </main>
</Layout>

<script>
  const EMAIL = "wade@hellowade.dev";

  const tip = document.querySelector<HTMLElement>(".wade-tip");
  const sheet = document.querySelector<HTMLElement>(".wade-sheet");
  const backdrop = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-backdrop");
  const closeBtn = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-close");
  const copyBtn = sheet?.querySelector<HTMLButtonElement>(".wade-sheet-copy");
  const emailEl = sheet?.querySelector<HTMLElement>(".wade-sheet-email");
  const card = sheet?.querySelector<HTMLElement>(".wade-sheet-card");

  const open = () => {
    sheet?.setAttribute("aria-hidden", "false");
    document.documentElement.style.overflow = "hidden";
  };
  const close = () => {
    sheet?.setAttribute("aria-hidden", "true");
    document.documentElement.style.overflow = "";
  };

  tip?.addEventListener("click", (e) => {
    e.preventDefault();
    open();
  });

  backdrop?.addEventListener("click", close);
  closeBtn?.addEventListener("click", close);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && sheet?.getAttribute("aria-hidden") === "false") close();
  });

  copyBtn?.addEventListener("click", async () => {
    if (!copyBtn) return;
    try {
      await navigator.clipboard.writeText(EMAIL);
      copyBtn.setAttribute("data-copied", "true");
      copyBtn.setAttribute("aria-label", "Copied");
      setTimeout(() => {
        copyBtn.removeAttribute("data-copied");
        copyBtn.setAttribute("aria-label", "Copy email");
      }, 1400);
    } catch {
      // clipboard denied — fallback: select the email text so the user can
      // long-press → copy manually
      if (emailEl) {
        const range = document.createRange();
        range.selectNodeContents(emailEl);
        const sel = window.getSelection();
        sel?.removeAllRanges();
        sel?.addRange(range);
      }
    }
  });

  // Drag-to-close — Vaul-style drawer behavior.
  // Start drag only from "chrome" areas (handle / empty space), never from
  // buttons, links, or the email text, so clicks and selection still work.
  let dragStartY = 0;
  let dragY = 0;
  let dragging = false;
  const CLOSE_THRESHOLD = 120;   // px dragged down before we dismiss
  const CLOSE_VELOCITY = 0.7;    // px/ms — fast flick-down also dismisses
  let dragStartTime = 0;

  const isInteractive = (target: EventTarget | null): boolean => {
    if (!(target instanceof HTMLElement)) return false;
    return Boolean(target.closest("button, a, input, textarea, [role='button']"));
  };

  card?.addEventListener("pointerdown", (e) => {
    if (isInteractive(e.target) || sheet?.getAttribute("aria-hidden") !== "false") return;
    dragStartY = e.clientY;
    dragY = 0;
    dragStartTime = performance.now();
    dragging = true;
    card.classList.add("dragging");
    card.setPointerCapture(e.pointerId);
  });

  card?.addEventListener("pointermove", (e) => {
    if (!dragging || !card) return;
    const delta = e.clientY - dragStartY;
    // Rubber-band when dragging up (shouldn't open further than the rest state)
    dragY = delta > 0 ? delta : delta * 0.2;
    card.style.transform = `translateY(${dragY}px)`;
  });

  const endDrag = (e: PointerEvent) => {
    if (!dragging || !card) return;
    dragging = false;
    card.classList.remove("dragging");
    const velocity = dragY / Math.max(1, performance.now() - dragStartTime);
    if (dragY > CLOSE_THRESHOLD || velocity > CLOSE_VELOCITY) {
      // Smoothly slide to the closed position from wherever the finger left it,
      // then reset inline style once the CSS rule takes over.
      card.style.transform = "translateY(100%)";
      sheet?.setAttribute("aria-hidden", "true");
      document.documentElement.style.overflow = "";
      window.setTimeout(() => { card.style.transform = ""; }, 340);
    } else {
      card.style.transform = "";
    }
    dragY = 0;
  };
  card?.addEventListener("pointerup", endDrag);
  card?.addEventListener("pointercancel", endDrag);
</script>
