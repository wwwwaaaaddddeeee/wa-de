---
import Layout from "../layouts/Layout.astro";
import { LocationTags } from "../components/LocationTags";
import { CopyEmail } from "../components/CopyEmail";
import { LinkedInIcon, XIcon, GitHubIcon, FigmaIcon, InstagramIcon, SpotifyIcon, NpmIcon } from "../components/SocialIcons";
import Earworm from "../components/Earworm";
---

<Layout>
  <main
    class="flex min-h-screen items-center justify-center relative"
    style="background: var(--background); color: var(--foreground);"
  >
    <div class="flex flex-col items-center justify-center py-16 md:py-12 md:-mt-44 px-6 md:px-0">
      <div class="inline-flex flex-col items-start w-full max-w-[400px]" style="font-size: clamp(14.5px, 2.12vw, 22.3px); line-height: normal;">

        {/* Bio section */}
        <div class="w-full text-left" style="margin-top: clamp(10px, 1.5vh, 30px); font-size: 14px; line-height: 1.6;">
          <LocationTags
            client:load
            locations={[
              { city: "Los Angeles, CA", timezone: "PST", timeZoneId: "America/Los_Angeles", color: "#FFDF2B" },
              { city: "Memphis, TN", timezone: "CST", timeZoneId: "America/Chicago", color: "#0C6FE1" },
              { city: "New York City, NY", timezone: "EST", timeZoneId: "America/New_York", color: "#F73737" },
            ]}
          />
          <p class="m-0" style="margin-top: 64px;">
            Call me Wade – a designer, living, learning and building<br />in Memphis, TN. Lets figure it out!</p>
        </div>

        {/* Earworm widget */}
        <div class="w-full flex justify-start" style="margin-top: clamp(40px, 6vh, 72px); font-size: 14px;">
          <Earworm client:visible />
        </div>

        {/* Social links */}
        <div class="w-full flex flex-wrap items-center justify-start gap-2" style="margin-top: clamp(80px, 12vh, 144px); font-size: 14px;">
          <LinkedInIcon client:load />
          <XIcon client:load />
          <InstagramIcon client:load />
          <SpotifyIcon client:load />
          <FigmaIcon client:load />
          <GitHubIcon client:load />
          <NpmIcon client:load />
        </div>

        {/* Email */}
        <div class="w-full" style="margin-top: 20px; font-size: 14px;">
          <CopyEmail client:load email="wade@hellowade.dev" />
        </div>

      </div>
    </div>
  </main>
</Layout>
