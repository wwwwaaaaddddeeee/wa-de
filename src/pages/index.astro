---
import Layout from '@/layouts/Layout.astro'
import {
  GitHubContributions,
  GitHubContributionsFallback,
} from '@/components/github-contributions'
import { EmailPill } from '@/components/EmailPill'
import Earworm from '@/components/Earworm'
import SocialIcon from '@/components/SocialIcon.astro'
import { getCachedContributions, type Contributions } from '@/lib/get-cached-contributions'

const GITHUB_USERNAME = 'wwwwaaaaddddeeee'
const GITHUB_PROFILE_URL = 'https://github.com/wwwwaaaaddddeeee'
const YEAR = new Date().getFullYear()
const SINCE = `${YEAR}-01-01`
const UNTIL = `${YEAR}-12-31`

let contributions: Contributions | null = null
try {
  contributions = await getCachedContributions(GITHUB_USERNAME, { since: SINCE, until: UNTIL })
} catch {
  contributions = null
}

const socials = [
  { label: 'GitHub', href: 'https://github.com/', icon: 'github' as const },
  { label: 'LinkedIn', href: 'https://linkedin.com/', icon: 'linkedin' as const },
  { label: 'Bird', href: 'https://x.com/', icon: 'x' as const },
  { label: 'Instagram', href: 'https://instagram.com/', icon: 'instagram' as const },
]
---

<Layout title="Wade — Designer in Memphis">
  <main class="min-h-screen w-full bg-white text-[#1a1a1a] dark:bg-[#171717] dark:text-[#ededed]">
    <div class="mx-auto w-full max-w-2xl px-8 sm:px-12 pt-16 sm:pt-20 pb-16 flex flex-col items-start gap-4">
      <img src="/avatar.png" alt="Wade" width="40" height="40" class="rounded-full" />

      <p class="text-[15px] leading-[22px] text-[#2e2e2e] dark:text-[#cfcfcf]">
        <span class="font-semibold text-[#1a1a1a] dark:text-[#ededed]">Wade</span>
        {' '}
        <span class="italic text-[#8c8c8c] dark:text-[#8b8b8b]">@brianawade</span>
        <span class="mx-2 text-[#9a9a9a] dark:text-[#777]" aria-hidden="true">–</span>
        Designing, learning and building in Memphis, TN with big Human Interface dreams.
      </p>

      <div class="h-3"></div>

      <div class="flex flex-wrap items-center gap-1.5">
        <EmailPill client:load email="wade@hellowade.dev" />
        <Earworm client:load />
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1 rounded-[5px] bg-[#f6f6f6] px-2 py-1 text-[11px] transition-colors hover:bg-[#efefef] dark:bg-[#222] dark:hover:bg-[#2e2e2e]"
          >
            <span class="text-[#0A0A0D] dark:text-[#ededed]">
              <SocialIcon name={s.icon} size={12} />
            </span>
            <span class="text-[#1F1F1F] dark:text-[#777]">{s.label}</span>
          </a>
        ))}
      </div>

      <div class="h-6"></div>

      <div class="grid w-full grid-cols-2 gap-4">
        {contributions ? (
          <GitHubContributions
            contributions={contributions}
            githubProfileUrl={GITHUB_PROFILE_URL}
            rangeLabel={`in ${YEAR}`}
          />
        ) : (
          <GitHubContributionsFallback />
        )}
        <div class="aspect-square w-full rounded-xl border border-black/[0.04] bg-white p-3 dark:border-white/5 dark:bg-[#1b1b1b]" aria-hidden="true"></div>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  function centerCurrentMonth() {
    document.querySelectorAll('[data-gh-scroll]').forEach((container) => {
      const svg = container.querySelector('svg')
      if (!svg) return
      const month = new Date().toLocaleString('en', { month: 'short', timeZone: 'UTC' })
      const label = Array.from(svg.querySelectorAll('text')).find(
        (t) => (t.textContent || '').trim() === month
      )
      if (!label) return
      const lr = label.getBoundingClientRect()
      const cr = container.getBoundingClientRect()
      const monthWidth = lr.width
      const targetX = lr.left - cr.left + container.scrollLeft + monthWidth / 2
      container.scrollLeft = targetX - container.clientWidth / 2
    })
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', centerCurrentMonth)
  } else {
    centerCurrentMonth()
  }
  window.addEventListener('load', centerCurrentMonth)
</script>
