---
import Layout from "../layouts/Layout.astro";
import { LocationTags } from "../components/LocationTags";
import { CopyEmail } from "../components/CopyEmail";
import { XIcon, GitHubIcon, FigmaIcon, InstagramIcon, SpotifyIcon } from "../components/SocialIcons";
import Earworm from "../components/Earworm";
---

<Layout>
  <main
    class="flex h-screen items-center justify-center bg-white text-black relative"
    style="font-family: 'Söhne', sans-serif;"
  >
    <div class="flex flex-col items-center justify-center py-12 -mt-0 md:-mt-44 px-6 md:px-0">
      <div class="inline-flex flex-col items-center w-full md:w-auto" style="font-size: clamp(14.5px, 2.12vw, 22.3px); line-height: normal;">

        {/* Bio section */}
        <div class="w-full text-center" style="margin-top: clamp(10px, 1.5vh, 30px); font-family: 'Söhne', sans-serif; font-size: 12px; line-height: 1.6;">
          <LocationTags
            client:load
            locations={[
              { city: "Los Angeles, CA", timezone: "PST", timeZoneId: "America/Los_Angeles", color: "#FFDF2B" },
              { city: "Memphis, TN", timezone: "CST", timeZoneId: "America/Chicago", color: "#0C6FE1" },
              { city: "New York City, NY", timezone: "EST", timeZoneId: "America/New_York", color: "#F73737" },
            ]}
          />
          <p class="m-0" style="margin-top: 28px;">
            Everyone calls me Wade. I am a designer turned aspiring design engineer, living and building in Memphis, TN.</p>
        </div>

        {/* Earworm widget */}
        <div class="w-full flex justify-center" style="margin-top: clamp(45px, 7vh, 90px); font-family: 'Söhne', sans-serif; font-size: 12px;">
          <Earworm client:visible />
        </div>

        {/* Social links + email */}
        <div class="w-full flex flex-wrap items-center justify-center gap-2" style="margin-top: clamp(45px, 7vh, 90px); font-family: 'Söhne', sans-serif; font-size: 12px;">
          <span class="mr-3">Reach out!</span>
          <XIcon client:load />
          <GitHubIcon client:load />
          <FigmaIcon client:load />
          <InstagramIcon client:load />
          <SpotifyIcon client:load />
          <span class="mr-1"></span>
          <CopyEmail client:load email="wade@hellowade.dev" />
        </div>

      </div>
    </div>
  </main>
</Layout>
