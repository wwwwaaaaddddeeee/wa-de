---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { Retune } from 'retune';

interface Props {
  title?: string;
}

const { title = "HELLOWADE" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content="Designer living and working in Memphis, TN." />
    <title>{title}</title>
  </head>
  <body>
    <style is:inline>
      :root {
        color-scheme: light dark;
        --background: #F9F9F9;
        --foreground: #000000;
        --muted: #999999;
        --faint: rgba(218, 218, 218, 0.15);
        --icon-default: #D5D5D5;
        --icon-hover: #777777;
        --track-title: #000000;
        --track-artist: #999999;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --background: #131313;
          --foreground: #e0e0e0;
          --muted: #888888;
          --faint: rgba(255, 255, 255, 0.08);
          --icon-default: #555555;
          --icon-hover: #aaaaaa;
          --track-title: #e0e0e0;
          --track-artist: #888888;
        }
      }
    </style>
    <slot />
    <Analytics />
    <SpeedInsights />
    <Retune client:only="react" />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
